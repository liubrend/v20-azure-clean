{
  "fail_threshold": "high",
  "allowed_external_imports": [
    "pytest",
    "httpx",
    "aiohttp",
    "requests",
    "security_precommit"
  ],
  "ignored_path_patterns": [
    ".git/**",
    ".pytest_cache/**",
    "__pycache__/**",
    "build/**",
    ".gradle/**",
    "dist/**",
    "node_modules/**"
  ],
  "prompt_injection_allowlist_paths": [
    "scripts/security_precommit.py",
    "backend/sample-service/src/test/java/com/v20azure/sample/agent/*.java",
    "security/guardrails_samples/*.py"
  ],
  "pii_allowlist_patterns": [
    "example.com"
  ]
}